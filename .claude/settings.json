{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Skill",
      "mcp__sonarcloud",
      "mcp__memory",
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_episodic-memory_episodic-memory__search"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push origin main)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_GLOB_TIMEOUT_SECONDS": "60"
  },
  "enableAllProjectMcpServers": true,
  "disabledMcpjsonServers": [],
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline-command.sh",
    "padding": 2
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-node.sh check-mcp-servers.js",
            "statusMessage": "Checking MCP availability...",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^compact$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-node.sh compact-restore.js",
            "continueOnError": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^[Bb]ash$",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "bash .claude/hooks/run-node.sh block-push-to-main.js",
            "statusMessage": "Checking push target..."
          }
        ]
      },
      {
        "matcher": "^(?i)read$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-node.sh large-file-gate.js",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^(?i)(write|edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-node.sh settings-guardian.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-node.sh pre-compaction-save.js",
            "continueOnError": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^[Bb]ash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-node.sh commit-tracker.js",
            "continueOnError": true
          }
        ]
      }
    ]
  }
}
