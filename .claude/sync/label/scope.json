{
  "version": 1,
  "description": "In-scope file patterns for the Piece 3 PostToolUse label hook. Glob-style patterns (minimatch-compatible).",
  "include": [
    ".claude/skills/**/*.md",
    ".claude/agents/**/*.md",
    ".claude/teams/**/*.md",
    ".claude/hooks/**/*.js",
    ".claude/hooks/**/*.cjs",
    ".claude/hooks/**/*.mjs",
    ".claude/hooks/**/*.sh",
    ".claude/canonical-memory/**/*.md",
    ".claude/output-styles/**/*.md",
    ".claude/sync/**/*.js",
    ".claude/sync/**/*.cjs",
    ".claude/sync/**/*.md",
    ".claude/sync/**/*.json",
    ".claude/settings.json",
    ".claude/settings.local.json",
    "scripts/**/*.js",
    "scripts/**/*.cjs",
    "scripts/**/*.mjs",
    "scripts/**/*.sh",
    "scripts/**/*.md",
    ".github/workflows/**/*.yml",
    ".github/workflows/**/*.yaml",
    ".husky/**/*",
    "tools/**/*.go",
    "tools/**/*.js",
    "tools/**/*.ts",
    "tools/**/*.md",
    "tools/**/*.sh",
    ".planning/**/PLAN.md",
    ".planning/**/DECISIONS.md",
    ".planning/**/DIAGNOSIS.md",
    ".planning/**/ROADMAP.md",
    ".planning/**/PORT_ANALYSIS.md",
    ".planning/**/LEARNINGS.md",
    ".planning/**/BRAINSTORM.md",
    ".planning/**/RESUME.md",
    ".planning/todos.jsonl",
    ".planning/DEBT_LOG.md",
    "CLAUDE.md",
    "README.md",
    ".nvmrc",
    ".gitignore",
    ".gitattributes",
    ".editorconfig",
    "package.json",
    "package-lock.json",
    "SESSION_CONTEXT.md"
  ],
  "exclude": [
    ".claude/sync/label/*.jsonl",
    ".claude/sync/label/preview/**",
    ".claude/sync/schema/*.jsonl",
    ".claude/state/**",
    ".claude/hooks/.session-agents.json",
    "**/node_modules/**",
    ".git/**",
    ".research/**",
    "**/__tests__/**",
    "**/*.test.js",
    "**/*.test.cjs"
  ],
  "comments": {
    "include": "Positive patterns are checked first; a file must match at least one to be in-scope.",
    "exclude": "Exclude patterns override include. .research/ is excluded for MVP noise reduction; revisit in S10 back-fill run if the census needs it. Tests are excluded because they are derived artifacts of the source they test; their type is already fixed by path.",
    "scope_json_self": "This scope.json file itself is in-scope via .claude/sync/**/*.json."
  }
}
