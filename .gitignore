/build/
/dist/
/out/
coverage/

# env / secrets
.env
.env.*
!.env.example
*.pem
tools/statusline/config.local.toml

# logs
*.log

# claude code — local state (committed: skills/agents/hooks/commands)
# State directory contents are machine-local EXCEPT for long-lived
# deep-plan state files, which travel cross-locale via git as a bridge
# until /context-sync (cross-repo-movement-reframe plan) absorbs them.
# Bridge retirement is a closeout-phase task in that plan.
.claude/state/*
!.claude/state/deep-plan.*.state.json
.claude/tmp/
.claude/projects/
.claude/settings.local.json
.claude/hook-warnings.json
.claude/alerts-acknowledged.json
.claude/session-activity.jsonl
.claude/override-log.jsonl
.claude/hooks/.*-state.json
.claude/sync/label/preview/

# claude code — machine-specific binaries (will rebuild per platform)
tools/**/*.exe
tools/**/bin/
tools/statusline/jason-statusline-v*
!tools/statusline/jason-statusline-v*.go

# repo-analysis — repomix dumps and copied source/ trees are large,
# machine-local, regeneratable. Per .claude/skills/repo-analysis/SKILL.md
# output spec, repomix-output.txt is gitignored; per Phase 2 (Dimension Wave),
# large repos copy their clone into source/ for agent processing — that
# directory must NEVER be committed (would import external repo code).
# The rest of .research/analysis/<slug>/ artifacts ship.
.research/analysis/*/repomix-output.txt
.research/analysis/*/source/
